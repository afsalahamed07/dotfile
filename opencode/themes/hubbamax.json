{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg0": "#1c1c1c",
    "bg1": "#262626",
    "bg2": "#303030",
    "fg0": "#bcbcbc",
    "fg1": "#9e9e9e",
    "fg2": "#767676",
    "red": "#af5f5f",
    "pink": "#d75f87",
    "green": "#5faf5f",
    "green2": "#87d787",
    "yellow": "#af875f",
    "yellow2": "#d7af87",
    "blue": "#5f87af",
    "blue2": "#5fafd7",
    "magenta": "#af87af",
    "magenta2": "#d787d7",
    "cyan": "#5f8787",
    "cyan2": "#87afaf"
  },
  "theme": {
    "primary": {
      "dark": "cyan2",
      "light": "blue"
    },
    "secondary": {
      "dark": "blue2",
      "light": "blue"
    },
    "accent": {
      "dark": "yellow2",
      "light": "yellow"
    },
    "error": {
      "dark": "pink",
      "light": "red"
    },
    "warning": {
      "dark": "yellow2",
      "light": "yellow"
    },
    "success": {
      "dark": "green2",
      "light": "green"
    },
    "info": {
      "dark": "blue2",
      "light": "blue"
    },
    "text": {
      "dark": "fg0",
      "light": "bg0"
    },
    "textMuted": {
      "dark": "fg2",
      "light": "bg2"
    },
    "background": {
      "dark": "bg0",
      "light": "fg0"
    },
    "backgroundPanel": {
      "dark": "bg1",
      "light": "fg1"
    },
    "backgroundElement": {
      "dark": "bg2",
      "light": "fg1"
    },
    "border": {
      "dark": "bg2",
      "light": "fg2"
    },
    "borderActive": {
      "dark": "cyan2",
      "light": "blue"
    },
    "borderSubtle": {
      "dark": "bg2",
      "light": "fg2"
    },
    "diffAdded": {
      "dark": "green2",
      "light": "green"
    },
    "diffRemoved": {
      "dark": "pink",
      "light": "red"
    },
    "diffContext": {
      "dark": "fg2",
      "light": "bg2"
    },
    "diffHunkHeader": {
      "dark": "blue2",
      "light": "blue"
    },
    "diffHighlightAdded": {
      "dark": "green2",
      "light": "green"
    },
    "diffHighlightRemoved": {
      "dark": "pink",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "#243024",
      "light": "#d8f0d8"
    },
    "diffRemovedBg": {
      "dark": "#302424",
      "light": "#f0d8d8"
    },
    "diffContextBg": {
      "dark": "bg1",
      "light": "fg1"
    },
    "diffLineNumber": {
      "dark": "fg2",
      "light": "bg2"
    },
    "diffAddedLineNumberBg": {
      "dark": "#243024",
      "light": "#d8f0d8"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#302424",
      "light": "#f0d8d8"
    },
    "markdownText": {
      "dark": "fg0",
      "light": "bg0"
    },
    "markdownHeading": {
      "dark": "cyan2",
      "light": "blue"
    },
    "markdownLink": {
      "dark": "blue2",
      "light": "blue"
    },
    "markdownLinkText": {
      "dark": "cyan2",
      "light": "cyan"
    },
    "markdownCode": {
      "dark": "green2",
      "light": "green"
    },
    "markdownBlockQuote": {
      "dark": "fg2",
      "light": "bg2"
    },
    "markdownEmph": {
      "dark": "yellow2",
      "light": "yellow"
    },
    "markdownStrong": {
      "dark": "magenta2",
      "light": "magenta"
    },
    "markdownHorizontalRule": {
      "dark": "fg2",
      "light": "bg2"
    },
    "markdownListItem": {
      "dark": "cyan2",
      "light": "blue"
    },
    "markdownListEnumeration": {
      "dark": "yellow2",
      "light": "yellow"
    },
    "markdownImage": {
      "dark": "magenta2",
      "light": "magenta"
    },
    "markdownImageText": {
      "dark": "cyan2",
      "light": "cyan"
    },
    "markdownCodeBlock": {
      "dark": "fg1",
      "light": "bg1"
    },
    "syntaxComment": {
      "dark": "fg2",
      "light": "bg2"
    },
    "syntaxKeyword": {
      "dark": "magenta2",
      "light": "magenta"
    },
    "syntaxFunction": {
      "dark": "blue2",
      "light": "blue"
    },
    "syntaxVariable": {
      "dark": "fg0",
      "light": "bg0"
    },
    "syntaxString": {
      "dark": "green2",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "yellow2",
      "light": "yellow"
    },
    "syntaxType": {
      "dark": "cyan2",
      "light": "cyan"
    },
    "syntaxOperator": {
      "dark": "pink",
      "light": "red"
    },
    "syntaxPunctuation": {
      "dark": "fg1",
      "light": "bg1"
    }
  }
}
