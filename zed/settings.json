{
  "ssh_connections": [
    {
      "host": "github.com",
      "projects": []
    }
  ],
  "languages": {
    "HTML": {
      "show_edit_predictions": true
    }
  },
  "show_edit_predictions": false,
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 16,
  // editor font settings
  // "buffer_font_family": "Space Mono",
  // "buffer_font_family": "Maple Mono NF",
  "buffer_font_family": "MonoLisa",
  "buffer_font_size": 18,
  "buffer_line_height": {
    "custom": 1.6
  },
  // "buffer_font_family": "Monolisa",
  // "buffer_font_size": 18,
  // "buffer_line_height": {
  //   "custom": 1.6
  // },
  // disabale format on save
  "format_on_save": "off",
  "theme": "Rosé Pine",
  // "theme": "Gruvbox Dark Hard",
  "relative_line_numbers": true,
  "vertical_scroll_margin": 8,
  "cursor_blink": true,
  "scrollbar": {
    "show": "never"
  },
  "terminal": {
    "font_size": 18,
    "font_family": "Hack Nerd Font",
    "line_height": {
      "custom": 1.7
    }
  },
  "project_panel": {
    "dock": "right"
  },

  "tab_bar": {
    "show": false
  },

  "wrap_guides": [80, 120],

  "experimental.theme_overrides": {
    "background.appearance": "opaque",
    "background": "#000000", // solid black background
    "editor.background": "#000000",
    "editor.gutter.background": "#000000",
    "terminal.background": "#000000",
    "toolbar.background": "#000000",
    "status_bar.background": "#000000", // Rosé Pine base
    "title_bar.background": "#000000",
    "panel.background": "#000000",
    "border.variant": "#000000", // subtle Rosé Pine surface
    "scrollbar.track.border": "#000000",
    "editor.active_line.background": "#2a273f", // Rosé Pine highlight (kept opaque)

    // Optional (if you want tab bar styled like Rosé Pine)
    "tab_bar.background": "#191724",
    "tab.active_background": "#26233a",
    "tab.inactive_background": "#1f1d2e"
  }
}
